# ForgeChat — variables d'environnement requises
# Copier en .env puis remplir les vraies valeurs. Ne jamais committer .env.

# Postgres
POSTGRES_PASSWORD=

# Backend (server/src/config.rs)
DATABASE_URL=postgres://forgechat:${POSTGRES_PASSWORD}@postgres:5432/forgechat
REDIS_URL=redis://redis:6379
JWT_SECRET=
FRONTEND_URL=https://forgechat.heiphaistos.org
