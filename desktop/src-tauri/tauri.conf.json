{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ForgeChat",
  "version": "3.2.0",
  "identifier": "org.heiphaistos.forgechat",
  "build": {
    "frontendDist": "../../client/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "cd ../client && npm run dev",
    "beforeBuildCommand": "cd ../client && npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "ForgeChat",
        "width": 1280,
        "height": 800,
        "minWidth": 940,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "center": true,
        "userAgent": "ForgeChat/3.2.0 (Desktop; Windows)"
      }
    ],
    "security": {
      "csp": "default-src 'self' https://forgechat.heiphaistos.org wss://forgechat.heiphaistos.org; img-src 'self' https://forgechat.heiphaistos.org data: blob: https:; media-src 'self' blob: mediastream:; style-src 'self' 'unsafe-inline' https://forgechat.heiphaistos.org; script-src 'self' 'unsafe-inline' https://forgechat.heiphaistos.org; connect-src 'self' https://forgechat.heiphaistos.org wss://forgechat.heiphaistos.org https://api.tenor.com; worker-src 'self' blob:; frame-src 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "languages": ["French"],
        "displayLanguageSelector": false,
        "installMode": "both",
        "shortcuts": {
          "desktop": true,
          "startMenu": true
        }
      },
      "wix": null
    },
    "resources": [],
    "createUpdaterArtifacts": false
  }
}
